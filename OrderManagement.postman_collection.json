{
  "info": {
    "name": "OrderManagement API",
    "description": "Collection for testing the OrderManagement API endpoints. Use {{baseUrl}} to configure the target host.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "orderId",
      "value": "00000000-0000-0000-0000-000000000000",
      "type": "string"
    },
    {
      "key": "rowVersion",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Create Order",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Idempotency-Key",
            "value": "test-order-123",
            "description": "Unique idempotency key for repeated requests"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customerId\": \"00000000-0000-0000-0000-000000000001\",\n  \"items\": [\n    {\n      \"productId\": \"00000000-0000-0000-0000-000000000002\",\n      \"quantity\": 2\n    }\n  ],\n  \"shippingAddress\": \"123 Main St, Jakarta\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/orders/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "orders",
            ""
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Order",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/orders/{{orderId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "orders",
            "{{orderId}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "List Orders",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/orders?status=Pending&page=1&pageSize=20",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "orders"
          ],
          "query": [
            {
              "key": "status",
              "value": "Pending"
            },
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "pageSize",
              "value": "20"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Update Order Status",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "If-Match",
            "value": "{{rowVersion}}",
            "description": "Current order row version value"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"Confirmed\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/orders/{{orderId}}/status",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "orders",
            "{{orderId}}",
            "status"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Cancel Order",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "If-Match",
            "value": "{{rowVersion}}",
            "description": "Current order row version value"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/orders/{{orderId}}/cancel",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "orders",
            "{{orderId}}",
            "cancel"
          ]
        }
      },
      "response": []
    }
  ]
}
